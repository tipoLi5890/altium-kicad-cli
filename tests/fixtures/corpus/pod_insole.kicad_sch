	(text "V3V3 rail = 3.0V (BUCK2, RVSET2=150k, nPM1300 PS Table 19)\nNOT 3.3V - SAADC vref-mv=750 / LED margin / RVSET2 assume 3.0V\nNRST: 10k pullup + 100n (ESD hardening, 2026-07-16)"
		(exclude_from_sim no)
		(at 771.652 68.58 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "2a19a84c-ba3b-5057-9508-dffebcd8a442")
	)
	(text "每線: 10k→V3V3_FSR + 1k→4051 + TPD4E05U06 對地 ESD (IO=1/2/4/5, GND=3/8, DS 表4-2)。U7 餘 2ch 護 CC1/CC2。CC: Rd 5.1k 1% 常在 + 10k sense 上拉(CC_PULL_EN 閘控) + 1k→AIN + BAT54S 箝 V3V3/GND (series: 1=A→GND, 2=C→V3V3, 3=A/C→CC)。INH 100k→V3V3 (reset 窗關斷)。4051 未用 Y6/Y7→GND"
		(exclude_from_sim no)
		(at 773.938 162.306 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "4b5ae303-3908-5aab-9dd8-aad26030ce34")
	)
	(text "TEST POINTS (§11: layout 凍結前必佈). SWD 全套=J4 TC2030 pad 兼 TP; PIEZO_P/N=J3 fallback pad 兼 TP. TP17-22=備用腳(§5.1)"
		(exclude_from_sim no)
		(at 773.938 172.466 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "4eccc43a-0b02-50c6-833b-3bb5540c49a5")
	)
	(text "Tone driver §5.3 接法A: P0.13→1A, P0.22→2A (dual-input, NEVER series). 100R each output. Piezo BZ1 pod-soldered; J3 = TONE fallback pads (TP). Xtal caps 8pF (CL=7pF, AN2867)"
		(exclude_from_sim no)
		(at 773.938 141.986 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "6506b631-9c06-50af-be14-5132eb0cc877")
	)
