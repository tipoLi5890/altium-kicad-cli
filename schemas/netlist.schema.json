{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://altium-kicad-cli/schemas/netlist.schema.json",
  "title": "AkcliNetlist",
  "description": "Net membership + Altium net-naming rules. Net identity is membership-derived (stable_id = sha1 of sorted (designator,pin) members), NEVER coordinate-derived. Same-name labels/power ports across disjoint clusters MUST merge into one net (the STAT/LED1 fix); naming priority is power-port > net-label > auto; single-pin nets are gated by NetlistSinglePinNets.",
  "type": "object",
  "required": ["schema_version", "source_format", "nets"],
  "properties": {
    "schema_version": { "const": "1.1" },
    "source_path": { "type": "string" },
    "source_format": { "enum": ["altium", "kicad"] },
    "naming_rules": {
      "type": "object",
      "properties": {
        "same_name_merge": { "type": "boolean", "default": true },
        "name_priority": {
          "type": "array",
          "items": { "enum": ["power_port", "net_label", "auto"] }
        },
        "power_port_priority": { "type": "boolean" },
        "emit_single_pin_nets": { "type": "boolean" }
      }
    },
    "nets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "members"],
        "properties": {
          "name": { "type": "string" },
          "stable_id": { "type": "string", "pattern": "^net_[0-9a-f]{12}$" },
          "members": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "source_names": { "type": "array", "items": { "type": "string" } },
          "is_named": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "merge_reasons": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
